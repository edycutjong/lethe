# Lethe CLI Configuration
# Copy this file to .env or .env.local in this directory (or the root directory) to configure CLI settings.

# Coordinator Agent gateway URL
AGENT_URL=http://localhost:8080

# secp256k1 uncompressed public key for ECIES encryption (starts with 04)
# Used for encrypting PII during campaigns
NEXT_PUBLIC_ENCLAVE_PUB_KEY=your_secp256k1_public_key_here

# secp256k1 private key for benchmark decryption (32-byte hex)
# Used for measuring TEE decryption latency in benchmark runs
ENCLAVE_PRIVATE_KEY=your_secp256k1_private_key_here
