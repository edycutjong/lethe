# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Lethe — Environment Variables                                             ║
# ║                                                                            ║
# ║  WHICH FILE TO USE:                                                        ║
# ║  ─────────────────                                                         ║
# ║  • Local development  →  .env.local   (gitignored, loaded by Next.js       ║
# ║                                        and Node.js automatically)          ║
# ║  • Production (Railway) → Set via Railway Dashboard > Variables            ║
# ║  • Production (Docker) →  .env.production  or  docker --env-file           ║
# ║  • CI / GitHub Actions →  Repository Secrets (Settings > Secrets)          ║
# ║                                                                            ║
# ║  SETUP:                                                                    ║
# ║  ──────                                                                    ║
# ║  1. Copy this file:   cp .env.example .env.local                          ║
# ║  2. Fill in the ACTIVE values below. The RESERVED block is optional.       ║
# ║  3. NEVER commit .env.local — it is gitignored.                            ║
# ║                                                                            ║
# ║  NEXT.JS CONVENTION:                                                       ║
# ║  ───────────────────                                                       ║
# ║  Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.          ║
# ║  All other variables are server-side only (agent, scripts, cli).           ║
# ║                                                                            ║
# ║  ⚠️  Only the ACTIVE variables are read by the current code. Each one       ║
# ║     lists the exact source location that consumes it. The RESERVED block   ║
# ║     documents the intended production wiring but is not read yet.          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ════════════════════════════════════════════════════════════════════════════════
#  ACTIVE — read by the running code. The local demo needs only these.
# ════════════════════════════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Identity (Tenant DID)                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# Terminal 3 Tenant DID (decentralized identifier).
# Format: did:t3n:<40-char hex>
# Read by: agent  →  agent/src/index.ts:109, :253  (falls back to did:t3n:sophie123)
DID=did:t3n:0123456789abcdef0123456789abcdef01234567

# Same DID, exposed to the browser for the dashboard header.
# ⚠️  Must be a did:t3n:… value — NOT your API key.
# Read by: ui  →  ui/src/app/page.tsx:145, :218, :296
NEXT_PUBLIC_T3N_DID=did:t3n:0123456789abcdef0123456789abcdef01234567


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Coordinator Agent endpoint                                                  │
# └──────────────────────────────────────────────────────────────────────────────┘

# Port the Express coordinator agent listens on.
# Read by: agent  →  agent/src/index.ts:10   (default: 8080)
PORT=8080

# Agent URL as seen by the browser / CLI. Leave commented for a purely local run
# (it defaults to http://localhost:8080). Set it only if the agent is deployed
# elsewhere — e.g. https://lethe-agent.fly.dev
# Read by: ui  →  ui/src/app/page.tsx:37 and the /api/* routes
# Read by: cli →  cli/src/index.ts:10  (cli also accepts AGENT_URL)
# NEXT_PUBLIC_AGENT_URL=http://localhost:8080
# AGENT_URL=http://localhost:8080


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Enclave Keypair (secp256k1) — ECIES encrypt/decrypt pair                    │
# │                                                                              │
# │  The UI/CLI encrypt PII to the PUBLIC key; the agent decrypts with the       │
# │  PRIVATE key. These two MUST be a matching keypair or decryption fails.      │
# │  Keep the demo pair below as-is, or regenerate BOTH together.                │
# │                                                                              │
# │  ⚠️  In production the private key is sealed inside the TEE and never        │
# │     exposed. The values below are for the sandbox/demo only.                 │
# └──────────────────────────────────────────────────────────────────────────────┘

# secp256k1 private key (32-byte hex, NO 0x prefix).
# Read by: agent  →  agent/src/index.ts:38   ·  cli  →  cli/src/index.ts:12
ENCLAVE_PRIVATE_KEY=your_secp256k1_private_key_here

# secp256k1 uncompressed public key (65-byte hex, starts with 04) — partner of the key above.
# Read by: ui  →  ui/src/app/page.tsx:36   ·  cli  →  cli/src/index.ts:11
NEXT_PUBLIC_ENCLAVE_PUB_KEY=your_secp256k1_public_key_here


# ════════════════════════════════════════════════════════════════════════════════
#  RESERVED — documents the intended production wiring. NOT read by code today.
#  (In the current build the agent simulates the Terminal 3 host APIs, x402
#  settlement, and broker egress locally, so these values have no effect yet.)
#  Leave them out of .env.local unless/until the integration is wired up.
# ════════════════════════════════════════════════════════════════════════════════

# Terminal 3 API key (from your T3 claim page / TOKEN.md). Stored here for when the
# real TEE contract integration is wired up.
# ⚠️  Real secret — has NO effect today (no code reads it).
#     Never paste a real key into this .env.example file.
# T3N_API_KEY=your_t3n_api_key_here

# Terminal 3 sandbox enclave host endpoint (intended target for contract execution).
# Not read by code yet (the agent runs the simulated enclave in-process).
# ENCLAVE_URL=https://sandbox.terminal3.io

# BOT Chain RPC endpoint for on-chain x402 verification.
# Not read by code yet (the API route currently uses a fixed sandbox rpcUrl).
# RPC_URL=https://rpc.bot-chain.sandbox.test

# USDC stablecoin contract address (6 decimals) — escrow/collateral transfers.
# Not read by code yet.
# USDC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# LetheStakingRegistry.sol deployed address — staking / x402 challenge verification.
# Not read by code yet.
# STAKING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
