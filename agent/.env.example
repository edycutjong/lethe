# Lethe coordinator agent — environment template.
# Copy this file to .env and configure the variables.

# Port the Express agent listens on.
PORT=8080

# Tenant DID used in agent logs / job records.
DID=did:t3n:your_tenant_did_here

# secp256k1 private key for ECIES decryption (hex format).
# Must be the partner of the UI's public key.
ENCLAVE_PRIVATE_KEY=your_secp256k1_private_key_here
